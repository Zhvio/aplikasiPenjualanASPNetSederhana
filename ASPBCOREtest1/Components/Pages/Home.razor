@page "/"
@rendermode InteractiveServer

<PageTitle>DaftarProduk</PageTitle>

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Selamat Datang</h1>
        <p class="lead text-muted">Ini adalah Daftar Produk kami.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var product in ListProduk)
        {
            <div class="col">
               
                <div class="card h-100 shadow-sm border-0 product-card">
                     <a href="/product/@product.Id" class="text-decoration-none text-dark">
                    <img src="@product.GambarUrl"
                         class="card-img-top img-fluid p-3 rounded"
                         alt="@product.Nama"
                         style="object-fit: cover; height: 200px;">
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-semibold">@product.Nama</h5>
                        <p class="card-text text-muted text-truncate" style="max-height: 50px;">
                            @product.DeskripsiSingkat
                        </p>
                        
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-success">
                                @product.HargaDisplay
                            </span>
                            <button class="btn btn-outline-primary btn-sm px-3 rounded-pill"
                                    @onclick="() => BeliProduk(product)">
                                Beli
                            </button>
                        </div>
                    </div>
                </div>
                
            </div>
        }
    </div>
</div>